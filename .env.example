# AURA — environment configuration template
#
# Copy this file to `.env` in the project root and fill in the values you need:
#
#   cp .env.example .env
#
# `.env` is loaded automatically (see config/settings.py, env_prefix="AURA_"),
# so every variable below must be prefixed with AURA_. Never commit your
# real `.env` — only this template.

AURA_PLANNER_BACKEND=local_llm
AURA_VISION_CONFIDENCE_THRESHOLD=0.8
AURA_PLANNER_BACKEND=heuristic
AURA_LOCAL_LLM_MODEL_PATH=path/to/your/model.gguf

# -----------------------------------------------------------------------
# Phase V — cloud/remote LLM planner backend (generic OpenAI-compatible,
# decisions.md D-044). Off by default; leave AURA_ENABLE_CLOUD_PLANNER
# unset/false unless you deliberately want a network-capable planner path.
# -----------------------------------------------------------------------
AURA_ENABLE_CLOUD_PLANNER=false
AURA_CLOUD_LLM_BASE_URL=https://api.openai.com/v1
AURA_CLOUD_LLM_API_KEY=
AURA_CLOUD_LLM_MODEL=gpt-4o-mini
# "local_first" (default) or "cloud_first" -- which LLM backend the
# auto-detection matrix prefers when both a bundled local model and a
# configured+enabled cloud backend are available.
AURA_PLANNER_PRIORITY=local_first
# If true, generate_spec() must never silently fall back to the heuristic
# backend -- fails fast at startup instead if no LLM backend is usable.
AURA_REQUIRE_LLM_BACKEND=false

# -----------------------------------------------------------------------
# Admin seed user (api/user_store.py)
# -----------------------------------------------------------------------
# On first run, AURA seeds one admin user ("admin") into config/users.json.
# Set this to control that password yourself; if left unset, AURA generates
# a random one and prints it once to stderr on first run.
AURA_ADMIN_PASSWORD=change-me-to-a-strong-password

# -----------------------------------------------------------------------
# OAuth — Google sign-in (api/routers/auth.py)
# -----------------------------------------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must exactly match:
#   {AURA_OAUTH_REDIRECT_BASE}/api/v1/auth/oauth/google/callback
# Leave blank to disable Google sign-in (the button will show a
# "not configured" message instead of failing).
AURA_GOOGLE_CLIENT_ID=
AURA_GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------
# OAuth — GitHub sign-in (api/routers/auth.py)
# -----------------------------------------------------------------------
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL must exactly match:
#   {AURA_OAUTH_REDIRECT_BASE}/api/v1/auth/oauth/github/callback
# Leave blank to disable GitHub sign-in.
AURA_GITHUB_CLIENT_ID=
AURA_GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------
# OAuth redirect base
# -----------------------------------------------------------------------
# The public base URL of this server. Used to build the callback URLs
# above. Update this (and your OAuth app settings) if you deploy anywhere
# other than local dev.
AURA_OAUTH_REDIRECT_BASE=http://localhost:8000

# -----------------------------------------------------------------------
# Human-in-the-loop tuning (config/settings.py) — optional, sane defaults
# -----------------------------------------------------------------------
# How often (seconds) AURA polls the screen for a human-in-the-loop step.
# AURA_HUMAN_ACTION_POLL_INTERVAL_SECONDS=2.0
#
# How long (seconds) to wait for a human-in-the-loop step before giving up.
# 0 means wait indefinitely (the default).
# AURA_HUMAN_ACTION_TIMEOUT_SECONDS=0
